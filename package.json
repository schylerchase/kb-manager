{
  "name": "kb-manager",
  "version": "0.2.0",
  "description": "MOC-first knowledge base automation for Obsidian.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "package:installer": "npm run build && node scripts/package-installer.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "knowledge-base",
    "moc",
    "toc",
    "tags"
  ],
  "author": "Schyler Ryan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/schylerchase/kb-manager.git"
  },
  "bugs": {
    "url": "https://github.com/schylerchase/kb-manager/issues"
  },
  "homepage": "https://github.com/schylerchase/kb-manager#readme",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.28.0",
    "obsidian": "^1.12.3",
    "tslib": "2.4.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.6"
  }
}
